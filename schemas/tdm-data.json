{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/itdoliva/alana-tdm@main/schemas/tdm-data.json",
  "title": "Alana - Teoria da Mudança",
  "type": "object",

  "properties": {
    "$schema": {
      "type": "string",
      "description": "Permite que o arquivo de dados aponte para este schema."
    },
    "estrategias": {
      "type": "array",
      "items": { "$ref": "#/$defs/option" }
    },
    "publicos": {
      "type": "array",
      "items": { "$ref": "#/$defs/option" }
    },
    "niveis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "descricao": { "type": "string" }
        }
      }
    },
    "resultados": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id_nivel": {
            "type": "string"
          },
          "descricao": { "type": "string" },
          "id_estrategias": {
            "type": "array",
            "items": { "$ref": "#/$defs/option_id" }
          },
          "id_publicos": {
            "type": "array",
            "items": { "$ref": "#/$defs/option_id" }
          }
        },
        "required": ["id_nivel", "descricao", "id_estrategias", "id_publicos"],
        "additionalProperties": false
      }
    }
  },
  "required": ["niveis", "estrategias", "publicos", "resultados"],
  "additionalProperties": false,

  "$defs": {
    "option_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "pattern": "^\\w\\d{2}$"
    },
    "option": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/$defs/option_id" },
        "nome": { "type": "string" }
      },
      "required": ["id", "nome"],
      "additionalProperties": false
    }
  }
}
